local function avaliarExpressao(expr)
    expr = expr:gsub("×", "*"):gsub("÷", "/")
    expr = expr:gsub("√([%d%.]+)", "math.sqrt(%1)")
    expr = expr:gsub("([%d%.]+)%^([%d%.]+)", "math.pow(%1,%2)")
    local func = loadstring("return " .. expr)
    if func then
        local sucesso, resultado = pcall(func)
        if sucesso then return tostring(resultado) end
    end
    return "Erro"
end

for _, txt in ipairs(calcButtons) do
