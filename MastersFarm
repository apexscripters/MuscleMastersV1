local function applySize2()
    local character = LocalPlayer.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        for _, value in ipairs(humanoid:GetChildren()) do
            if value:IsA("NumberValue") and value.Name:find("Scale") then
                if value.Value ~= 2 then value.Value = 2 end
            end
        end
    end
end

--Sistema de Combate e Restrição de Alvos (Apenas no Brawl)
local blockedAnimations = {
    ["rbxassetid://3638729053"] = true,
    ["rbxassetid://3638767427"] = true,
}

local function stopAnimations(humanoid)
    for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
        if track.Animation then
            local animId = track.Animation.AnimationId
            local animName = track.Name:lower()
            if blockedAnimations[animId] or animName:match("punch") or animName:match("attack") or animName:match("right") then
                track:Stop()
            end
        end
    end
end

local tickCounter = 0
RunService.Heartbeat:Connect(function()
    tickCounter = tickCounter + 1
    if tickCounter % 3 ~= 0 then return end 
    applySize2()
    
    -- O ataque só funciona se estivermos ativamente dentro da Arena do Brawl
    if not isInBrawlArena then return end

    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
        stopAnimations(char.Humanoid)
        local punchInBackpack = LocalPlayer.Backpack:FindFirstChild("Punch")
        local punchInCharacter = char:FindFirstChild("Punch")
        
        if punchInBackpack then
            punchInBackpack.Parent = char
            if punchInBackpack:FindFirstChild("attackTime") then punchInBackpack.attackTime.Value = 0 end
        end
        if punchInCharacter then
            if punchInCharacter:FindFirstChild("attackTime") then punchInCharacter.attackTime.Value = 0 end
            punchInCharacter:Activate()
        end
        
        local tool = char:FindFirstChildOfClass("Tool")
        if tool and (tool.Name:lower():find("punch") or tool.Name:lower():find("attack")) then
            pcall(function() tool:Activate() end)
        end
        
        local rightHand = char:FindFirstChild("RightHand")
        local leftHand = char:FindFirstChild("LeftHand")
        local myRoot = char:FindFirstChild("HumanoidRootPart")

        if rightHand and leftHand and myRoot then
            for _, target in ipairs(Players:GetPlayers()) do
                if target ~= LocalPlayer and target.Character then
                    local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
                    local targetHumanoid = target.Character:FindFirstChild("Humanoid")
                    
                    -- Condição crucial: Só ataca se o alvo estiver na mesma arena (raio de 150 studs)
                    if targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
                        local distance = (myRoot.Position - targetRoot.Position).Magnitude
                        if distance <= 150 then
                            pcall(function()
                                firetouchinterest(rightHand, targetRoot, 1)
                                firetouchinterest(leftHand, targetRoot, 1)
                                firetouchinterest(rightHand, targetRoot, 0)
                                firetouchinterest(leftHand, targetRoot, 0)
                            end)
                        end
                    end
                end
            end
        end
    end
end)

