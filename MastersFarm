--Lógica Dinâmica de Brawl e Server Hop (O Roteiro Principal)
local function ExecuteRealServerHop()
    title.Text = "Buscando Servidor..."
    local nextCursor = ""
    local serverFound = false
    while not serverFound do
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
        if nextCursor ~= "" then url = url .. "&cursor=" .. nextCursor end
        local success, result = pcall(function() return game:HttpGet(url) end)
        if success and result then
            local decoded = HttpService:JSONDecode(result)
            if decoded and decoded.data then
                local list = decoded.data
                -- Embaralha levemente para não cair sempre no mesmo
                for i = #list, 2, -1 do
                    local j = math.random(i)
                    list[i], list[j] = list[j], list[i]
                end
                for _, server in ipairs(list) do
                    -- Procura um servidor com BASTANTE gente (ex: acima de 15 jogadores) para farmar melhor
                    if server.id ~= game.JobId and server.playing and server.maxPlayers then
                        if server.playing < server.maxPlayers and server.playing >= 15 then
                            serverFound = true
                            pcall(function() TS:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer) end)
                            task.wait(2)
                            if not serverFound then break end
                        end
                    end
                end
                if decoded.nextPageCursor then nextCursor = decoded.nextPageCursor else break end
            else break end
        else break end
        task.wait(1)
    end
    -- Se falhar em achar um com +15, apenas pula de servidor normalmente
    if not serverFound then pcall(function() TS:Teleport(game.PlaceId, LocalPlayer) end) end
end

-- Monitorador Dinâmico de Tempo
task.spawn(function()
    local initialPosition = nil

    while task.wait(1) do
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        if root then
            -- Registra a posição inicial do jogador no servidor
            if not initialPosition then
                initialPosition = root.Position
            end

            -- Entrar automaticamente no Brawl (Dispara o evento de join padrão se existir)
            pcall(function()
                local rEvents = ReplicatedStorage:FindFirstChild("rEvents")
                if rEvents and rEvents:FindFirstChild("brawlEvent") then
                    rEvents.brawlEvent:FireServer("joinBrawl")
                end
            end)

            -- Detectar se o jogador foi teleportado para a arena (Distância > 1000 do respawn)
            local distanceFromStart = (root.Position - initialPosition).Magnitude

            if distanceFromStart > 1000 then
                if not isInBrawlArena then
                    isInBrawlArena = true
                    title.Text = "Em Combate! (Brawl)"
                end
            else
                -- Se estava na arena e voltou para o inicio (Brawl acabou ou você ganhou)
                if isInBrawlArena then
                    isInBrawlArena = false
                    title.Text = "Brawl Concluído!"
                    
                    -- Espera 5 segundos exatos após a vitória antes do pulo
                    task.wait(5)
                    ExecuteRealServerHop()
                end
            end
        end
    end
end)
