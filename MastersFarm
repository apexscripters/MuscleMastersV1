local function alternarAba(abaAtiva, botaoAtivo)
    P_Main.Visible = false
    P_Player.Visible = false
    P_Misc.Visible = false
    P_Calc.Visible = false
    P_Settings.Visible = false
    abaAtiva.Visible = true
    
    for _, btn in ipairs(Sidebar:GetChildren()) do
        if btn:IsA("TextButton") then
            btn.BackgroundColorTransparency = 1
            btn.TextColor3 = Color3.fromRGB(150, 150, 150)
            local indicator = btn:FindFirstChild("Indicator")
            if indicator then indicator.Visible = false end
        end
    end
    
    botaoAtivo.BackgroundColorTransparency = 0.9
    botaoAtivo.TextColor3 = Color3.fromRGB(255, 255, 255)
    local activeIndicator = botaoAtivo:FindFirstChild("Indicator")
    if activeIndicator then activeIndicator.Visible = true end
end

